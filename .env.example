# ============================================================
# ForgeSight AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=ForgeSight AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Security ─────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION — use: openssl rand -hex 64
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forgesight:forgesight@localhost:5432/forgesight
REDIS_URL=redis://localhost:6379/0

# ── Firebase (optional) ──────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Google Gemini API ─────────────────────────────────────────
GOOGLE_API_KEY=Ab8RN6KoMYxNHW3yy5Skncy15HSiNkUTRCq3WZTg-Jc8bZQusQ
GEMINI_MODEL=gemini-1.5-pro

# ── Federated Learning ────────────────────────────────────────
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_NUM_CLIENTS=4
FL_LOCAL_EPOCHS=3
FL_ROUNDS=50
FL_NOISE_SIGMA=0.5
FL_CLIPPING_NORM=1.0
FL_DIRICHLET_ALPHA=0.5

# ── Differential Privacy ─────────────────────────────────────
DP_TARGET_EPSILON=2.8
DP_TARGET_DELTA=1e-5

# ── MQTT ─────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000
